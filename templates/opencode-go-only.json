{
  "name": "OpenCode Go Only",
  "description": "Configuración replicando el artículo original — solo OpenCode Go con asignación clásica de modelos",
  "providers": ["opencode-go"],
  "accounts": {
    "opencode-go": [{ "id": "opencode-go-1", "label": "Cuenta Principal" }]
  },
  "agents": {
    "sisyphus": { "model": "kimi-k2.6", "source": "opencode-go-1", "fallbacks": ["openrouter-1/deepseek-v4-pro"] },
    "hephaestus": { "model": "deepseek-v4-pro", "source": "openrouter-1", "fallbacks": ["openrouter-1/deepseek-v4-flash"] },
    "oracle": { "model": "glm-5.2", "source": "opencode-go-1", "fallbacks": ["opencode-go-1/kimi-k2.6"] },
    "librarian": { "model": "deepseek-v4-flash", "source": "openrouter-1", "fallbacks": [] },
    "explore": { "model": "deepseek-v4-flash", "source": "openrouter-1", "fallbacks": [] },
    "multimodal-looker": { "model": "mimo-v2-omni", "source": "opencode-go-1", "fallbacks": [] },
    "prometheus": { "model": "glm-5.2", "source": "opencode-go-1", "fallbacks": ["opencode-go-1/qwen3.6-plus"] },
    "metis": { "model": "qwen3.6-plus", "source": "opencode-go-1", "fallbacks": ["openrouter-1/deepseek-v4-pro"] },
    "momus": { "model": "qwen3.6-plus", "source": "opencode-go-1", "fallbacks": ["opencode-go-1/kimi-k2.6"] },
    "atlas": { "model": "deepseek-v4-pro", "source": "openrouter-1", "fallbacks": ["openrouter-1/deepseek-v4-flash"] },
    "code-reviewer": { "model": "kimi-k2.6", "source": "opencode-go-1", "fallbacks": ["openrouter-1/deepseek-v4-pro"] },
    "sisyphus-junior": { "model": "deepseek-v4-flash", "source": "openrouter-1", "fallbacks": [] }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 180000
  }
}
