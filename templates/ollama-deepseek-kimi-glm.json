{
  "name": "Ollama Cloud: DeepSeek Flash (Principal) + Kimi 2.7 + GLM-5.2",
  "description": "Plantilla pura en Ollama Cloud usando DeepSeek-V4-Flash para orquestación, Kimi 2.7 para escritura de código, y GLM-5.2 para soporte ligero.",
  "providers": ["ollama-cloud"],
  "accounts": {
    "ollama-cloud": [{ "id": "ollama-cloud-1", "label": "Ollama Cloud API" }]
  },
  "agents": {
    "sisyphus": { "model": "deepseek-v4-flash", "source": "ollama-cloud-1", "fallbacks": [] },
    "hephaestus": { "model": "kimi-k2.7-code", "source": "ollama-cloud-1", "fallbacks": [] },
    "oracle": { "model": "glm-5.2", "source": "ollama-cloud-1", "fallbacks": [] },
    "librarian": { "model": "glm-5.2", "source": "ollama-cloud-1", "fallbacks": [] },
    "explore": { "model": "kimi-k2.7-code", "source": "ollama-cloud-1", "fallbacks": [] },
    "multimodal-looker": { "model": "deepseek-v4-flash", "source": "ollama-cloud-1", "fallbacks": [] },
    "prometheus": { "model": "deepseek-v4-flash", "source": "ollama-cloud-1", "fallbacks": [] },
    "metis": { "model": "kimi-k2.7-code", "source": "ollama-cloud-1", "fallbacks": [] },
    "momus": { "model": "glm-5.2", "source": "ollama-cloud-1", "fallbacks": [] },
    "atlas": { "model": "kimi-k2.7-code", "source": "ollama-cloud-1", "fallbacks": [] },
    "code-reviewer": { "model": "deepseek-v4-flash", "source": "ollama-cloud-1", "fallbacks": [] },
    "sisyphus-junior": { "model": "glm-5.2", "source": "ollama-cloud-1", "fallbacks": [] }
  }
}
