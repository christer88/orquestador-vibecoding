{
  "version": "1.0.0",
  "description": "Registro de proveedores con endpoints, autenticación y soporte multi-cuenta",
  "lastUpdated": "2026-06-07",
  "providers": [
    {
      "id": "nvidia",
      "name": "NVIDIA API",
      "description": "NVIDIA NIM Microservices with state-of-the-art models",
      "type": "api",
      "endpoint": "https://integrate.api.nvidia.com/v1",
      "testEndpoint": "https://integrate.api.nvidia.com/v1/models",
      "auth": {
        "method": "env_variable",
        "env_key_pattern": "NVIDIA_{N}_API_KEY",
        "auth_type": "bearer_token"
      },
      "multi_account": true,
      "max_accounts": 5,
      "supported_models": [
        "nvidia/nemotron-3-super-120b-a12b",
        "openai/gpt-oss-120b",
        "qwen/qwen3-next-80b-a3b-instruct",
        "nvidia/nemotron-3-ultra-550b-a55b",
        "z-ai/glm-5.1",
        "minimaxai/minimax-m2.7",
        "moonshotai/kimi-k2.6"
      ]
    },
    {
      "id": "opencode-go",
      "name": "OpenCode GO",
      "description": "Plataforma principal de desarrollo AI con soporte multi-modelo gratuito",
      "type": "platform",
      "endpoint": "https://opencode.ai/zen/go/v1",
      "testEndpoint": "https://opencode.ai/zen/go/v1/models",
      "auth": {
        "method": "env_variable",
        "env_key_pattern": "OPENCODE_GO_{N}_AUTH",
        "auth_type": "bearer_token",
        "login_command": "opencode auth login",
        "notes": "Requiere autenticación via CLI. Cada cuenta tiene rate limits independientes."
      },
      "multi_account": true,
      "max_accounts": 5,
      "rate_limit_strategy": "per_account",
      "supported_models": [
        "kimi-k2.6",
        "deepseek-v4-flash",
        "deepseek-v4-pro",
        "glm-5.1",
        "qwen3.6-plus",
        "qwen3.5-plus",
        "mimo-v2-omni",
        "mimo-v2.5-pro",
        "minimax-m2.5",
        "minimax-m2.7"
      ],
      "config_format": "opencode.json",
      "model_prefix": null,
      "features": {
        "streaming": true,
        "tool_use": true,
        "vision": true,
        "file_upload": true
      }
    },
    {
      "id": "openrouter",
      "name": "OpenRouter",
      "description": "Agregador de modelos AI con acceso unificado a múltiples proveedores",
      "type": "aggregator",
      "endpoint": "https://openrouter.ai/api/v1",
      "testEndpoint": "https://openrouter.ai/api/v1/auth/key",
      "auth": {
        "method": "api_key",
        "env_key_pattern": "OPENROUTER_API_KEY",
        "auth_type": "bearer_token",
        "header": "Authorization",
        "notes": "API key única. Soporta todos los modelos vía prefijo proveedor/modelo."
      },
      "multi_account": false,
      "max_accounts": 1,
      "rate_limit_strategy": "global",
      "supported_models": [
        "kimi-k2.6",
        "deepseek-v4-flash",
        "deepseek-v4-pro",
        "glm-5.1",
        "qwen3.6-plus",
        "qwen3.5-plus",
        "mimo-v2-omni",
        "mimo-v2.5-pro",
        "mimo-v2-flash",
        "minimax-m3",
        "minimax-m2.5",
        "minimax-m2.7"
      ],
      "config_format": "openrouter",
      "model_prefix": "{provider}/",
      "features": {
        "streaming": true,
        "tool_use": true,
        "vision": true,
        "file_upload": false
      }
